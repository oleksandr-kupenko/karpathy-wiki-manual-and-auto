# DeepSeek API key (optional — for automatic flush/compile)
# Get your key at https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-your-key-here

# Vault directory name (relative to compiler's parent, default: obsidian)
# WIKI_VAULT_DIR=obsidian

# Or absolute path to vault:
# WIKI_VAULT_PATH=/absolute/path/to/vault

# Timezone for daily logs (default: Europe/Kyiv)
# WIKI_TIMEZONE=Europe/Kyiv
